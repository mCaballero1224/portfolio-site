<main>
	<div id="contact-form">
		<form id="message-form">
			<fieldset>
				<legend>Drop a message</legend>

				<label for="fname">First Name:</label>
				<input type="text" id="fname" name="fname" placeholder="John">

				<label for="lname">Last Name:</label>
				<input type="text" id="lname" name="lname" placeholder="Doe">

				<label for="email">Email:</label>
				<input type="email" id="email" name="email" placeholder="johnd@mail.com">

				<label for="message">Message:</label>
				<textarea id="message" name="message" cols="50" rows="4" placeholder="Enter your message here (500 characters max)"></textarea>

				<input type="submit" value="Send" class="btn"/>
			</fieldset>
		</form>
		<form id="review-form">
			<fieldset>
				<legend>Leave a Review</legend>

				<label for="ease-of-navigation">Is the site easy to navigate?</label>
				<input name="ease-of-navigation" type="radio" value="yes">Yes</input>
				<input name="ease-of-navigation" type="radio" value="no">No</input>

				<label for="areas-of-interest">Did anything here catch your interest?</label>
				<textarea  name="areas-of-interest" cols="50" rows="4" placeholder="Let me know what caught your eye!"></textarea>

				<label for="improvements">Is there anything I could do to improve this site?</label>
				<textarea  name="areas-of-interest" cols="50" rows="4" placeholder="There's always room to improve, right?"></textarea>

				<label for="reccomendation">Would you reccomend this site to anyone?</label>
				<input name="reccomendation" type="radio" value="yes">Yes</input>
				<input name="reccomendation" type="radio" value="no">No</input>
				<input type="submit" value="Send" class="btn"/>
			</fieldset>
		</form>
	</div>
</main>
