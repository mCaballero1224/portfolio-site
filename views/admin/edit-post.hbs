<main>
	<form action="/delete-post/{{data._id}}?_method=DELETE" method="POST">
		<input type="submit" value="Delete">
	</form>
	<form action="/edit-post/{{data._id}}?_method=PUT" method="POST" class="edit-blog-form">
		<fieldset>
			<legend>View / Edit post</legend>
			
			<label for="title"><b>Title</b>: </label>
			<input type="text" placeholder="Post Title" name="title" value="{{data.title}}">

			{{#if data.published}}
			{{else}}
			<label for="published"><b></b>Submit as: </label>
			<input type="radio" name="published" value="true">Published</input>
			<input type="radio" name="published" value="false" checked>Draft</input>
			{{/if}}


			<label for="title"><b>Content</b>: </label>
			<textarea placeholder="Post Content" name="body" cols="50" rows="10">{{data.body}}</textarea>

			<input type="submit" value="Submit Edit" class="btn">
		</fieldset>
	</form>
	<a href="/dashboard">&larr; Back</a>
</main>
